# Araya Engine Configuration

# Core API
PROJECT_NAME="Araya Engine"
API_V1_STR="/api/v1"

# Database (Used by docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=araya
DATABASE_URL="postgresql://postgres:postgres@db:5432/araya"

# LLM & Vector DB
# Get your Gemini key from https://aistudio.google.com/
GOOGLE_API_KEY=your_gemini_key_here

# Get your Pinecone key from https://www.pinecone.io/
PINECONE_API_KEY=your_pinecone_key_here
PINECONE_INDEX_NAME="araya-research"
PINECONE_ENVIRONMENT=your_pinecone_env

# Specialized Tools
# Get your Deepgram key from https://deepgram.com/
DEEPGRAM_API_KEY=your_deepgram_key_here

# Get your Serper key from https://serper.dev/
SERPER_API_KEY=your_serper_key_here

# Observability (Optional)
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
# LANGCHAIN_API_KEY=your_langsmith_key_here
# LANGCHAIN_PROJECT="araya-engine"
